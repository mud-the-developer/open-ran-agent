{
  "name": "open-ran-agent-docs",
  "private": true,
  "description": "Cloudflare Pages-ready docs site for Open RAN Agent",
  "scripts": {
    "docs:dev": "vitepress dev docs --host 127.0.0.1 --port 4173",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs --host 127.0.0.1 --port 4173",
    "pages:dev": "wrangler pages dev docs/.vitepress/dist",
    "pages:deploy": "wrangler pages deploy docs/.vitepress/dist"
  },
  "devDependencies": {
    "@antv/infographic": "^0.2.16",
    "playwright-core": "^1.58.2",
    "vitepress": "^1.6.4",
    "wrangler": "^4.9.1"
  }
}
