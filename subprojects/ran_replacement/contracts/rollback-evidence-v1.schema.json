{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-ran-agent.local/subprojects/ran_replacement/contracts/rollback-evidence-v1.schema.json",
  "title": "RAN Replacement Rollback Evidence v1",
  "description": "Draft schema for replacement-track rollback evidence artifacts. The artifact captures why rollback was safer than leaving a failed milestone-1 lane up and what state was observed after recovery.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "rollback_id",
    "change_id",
    "incident_id",
    "target_profile",
    "rollback_target",
    "rollback_reason",
    "triggering_gate",
    "failure_class",
    "protocol_claims",
    "pre_rollback_state",
    "post_rollback_state",
    "recovery_check",
    "evidence_refs",
    "operator_notes"
  ],
  "properties": {
    "rollback_id": {
      "type": "string",
      "minLength": 1
    },
    "change_id": {
      "type": "string",
      "minLength": 1
    },
    "incident_id": {
      "type": "string",
      "minLength": 1
    },
    "target_profile": {
      "type": "string",
      "minLength": 1
    },
    "rollback_target": {
      "type": "string",
      "minLength": 1
    },
    "rollback_reason": {
      "type": "string",
      "minLength": 1
    },
    "triggering_gate": {
      "type": "string",
      "enum": [
        "blocked",
        "degraded",
        "pass"
      ]
    },
    "failure_class": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "ru_failure",
        "core_failure",
        "user_plane_failure",
        "cutover_or_rollback_failure",
        null
      ]
    },
    "protocol_claims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ngap",
        "f1_c",
        "e1ap",
        "f1_u",
        "gtpu"
      ],
      "properties": {
        "ngap": {
          "$ref": "#/$defs/ngapSubset"
        },
        "f1_c": {
          "$ref": "#/$defs/namedProcedureSubset"
        },
        "e1ap": {
          "$ref": "#/$defs/namedProcedureSubset"
        },
        "f1_u": {
          "$ref": "#/$defs/namedProcedureSubset"
        },
        "gtpu": {
          "$ref": "#/$defs/namedProcedureSubset"
        }
      }
    },
    "pre_rollback_state": {
      "type": "object",
      "additionalProperties": true
    },
    "post_rollback_state": {
      "type": "object",
      "additionalProperties": true
    },
    "recovery_check": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status",
        "checks"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "failed",
            "blocked",
            "degraded"
          ]
        },
        "checks": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "operator_notes": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "ngapSubset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standards_subset_ref",
        "procedure_matrix_ref",
        "required_procedures",
        "optional_procedures",
        "deferred_procedures"
      ],
      "properties": {
        "standards_subset_ref": {
          "type": "string",
          "const": "subprojects/ran_replacement/notes/06-ngap-and-registration-standards-subset.md"
        },
        "procedure_matrix_ref": {
          "type": "string",
          "const": "subprojects/ran_replacement/notes/09-ngap-procedure-support-matrix.md"
        },
        "required_procedures": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "NG Setup",
              "Initial UE Message",
              "Uplink NAS Transport",
              "Downlink NAS Transport",
              "UE Context Release"
            ]
          }
        },
        "optional_procedures": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "Error Indication",
              "Reset"
            ]
          }
        },
        "deferred_procedures": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "Paging",
              "Handover Preparation",
              "Path Switch Request"
            ]
          }
        }
      }
    },
    "namedProcedureSubset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standards_subset_ref",
        "procedure_matrix_ref",
        "required_procedures",
        "optional_procedures",
        "deferred_procedures"
      ],
      "properties": {
        "standards_subset_ref": {
          "type": "string",
          "minLength": 1
        },
        "procedure_matrix_ref": {
          "type": "string",
          "minLength": 1
        },
        "required_procedures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "optional_procedures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "deferred_procedures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
