{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-ran-agent.local/subprojects/ran_replacement/contracts/ranctl-ran-replacement-status-v1.schema.json",
  "title": "ranctl RAN Replacement Status v1",
  "description": "Draft response schema for replacement-track RAN actions. The status surface is designed for agents, dashboard actions, and remote execution against a real Open5GS-based core.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "command",
    "scope",
    "summary"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "failed",
        "blocked",
        "degraded"
      ]
    },
    "command": {
      "type": "string",
      "enum": [
        "precheck",
        "plan",
        "apply",
        "verify",
        "rollback",
        "observe",
        "capture-artifacts"
      ]
    },
    "scope": {
      "type": "string",
      "enum": [
        "gnb",
        "cu_cp",
        "cu_up",
        "du",
        "cell",
        "ru",
        "ru_link",
        "ue_session",
        "transport_profile",
        "target_host",
        "core_link",
        "replacement_cutover"
      ]
    },
    "change_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "incident_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "target_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "target_profile": {
      "type": [
        "string",
        "null"
      ]
    },
    "core_profile": {
      "type": [
        "string",
        "null"
      ]
    },
    "gate_class": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "blocked",
        "degraded",
        "pass",
        null
      ]
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "target_backend": {
      "type": [
        "string",
        "null"
      ]
    },
    "rollback_target": {
      "type": [
        "string",
        "null"
      ]
    },
    "approval_required": {
      "type": "boolean"
    },
    "rollback_available": {
      "type": "boolean"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "suggested_next": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "failed",
              "blocked",
              "degraded"
            ]
          },
          "detail": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "plane_status": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "s_plane": {
          "$ref": "#/$defs/plane_summary"
        },
        "m_plane": {
          "$ref": "#/$defs/plane_summary"
        },
        "c_plane": {
          "$ref": "#/$defs/plane_summary"
        },
        "u_plane": {
          "$ref": "#/$defs/plane_summary"
        }
      }
    },
    "interface_status": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ngap": {
          "$ref": "#/$defs/component_summary"
        },
        "f1_c": {
          "$ref": "#/$defs/component_summary"
        },
        "e1ap": {
          "$ref": "#/$defs/component_summary"
        },
        "f1_u": {
          "$ref": "#/$defs/component_summary"
        },
        "gtpu": {
          "$ref": "#/$defs/component_summary"
        },
        "ru_fronthaul": {
          "$ref": "#/$defs/component_summary"
        },
        "ptp": {
          "$ref": "#/$defs/component_summary"
        }
      }
    },
    "ru_status": {
      "$ref": "#/$defs/component_summary"
    },
    "core_link_status": {
      "$ref": "#/$defs/component_summary"
    },
    "attach_status": {
      "$ref": "#/$defs/component_summary"
    },
    "pdu_session_status": {
      "$ref": "#/$defs/component_summary"
    },
    "ping_status": {
      "$ref": "#/$defs/component_summary"
    },
    "rollback_status": {
      "$ref": "#/$defs/component_summary"
    }
  },
  "$defs": {
    "plane_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "failed",
            "blocked",
            "degraded"
          ]
        },
        "evidence_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "component_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "failed",
            "blocked",
            "degraded",
            "pending"
          ]
        },
        "evidence_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "command": {
            "const": "verify"
          }
        },
        "required": [
          "command"
        ]
      },
      "then": {
        "required": [
          "gate_class",
          "interface_status"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "capture-artifacts"
          }
        },
        "required": [
          "command"
        ]
      },
      "then": {
        "required": [
          "artifacts"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "scope": {
            "const": "ue_session"
          }
        },
        "required": [
          "scope"
        ]
      },
      "then": {
        "required": [
          "interface_status",
          "attach_status",
          "pdu_session_status",
          "ping_status"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "scope": {
            "const": "target_host"
          }
        },
        "required": [
          "scope"
        ]
      },
      "then": {
        "required": [
          "ru_status",
          "core_link_status"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "rollback"
          }
        },
        "required": [
          "command"
        ]
      },
      "then": {
        "required": [
          "rollback_status"
        ]
      }
    }
  ]
}
