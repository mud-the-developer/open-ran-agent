{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-ran-agent.local/subprojects/ran_replacement/contracts/ranctl-ran-replacement-status-v1.schema.json",
  "title": "ranctl RAN Replacement Status v1",
  "description": "Draft response schema for replacement-track RAN actions. The status surface is designed for agents, dashboard actions, and remote execution against a real Open5GS-based core, and it must declare whether the evidence is proof-only or a standards-subset claim.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "status",
    "command",
    "scope",
    "conformance_claim",
    "summary",
    "failure_class",
    "ngap_subset",
    "protocol_claims"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "ok",
        "failed",
        "blocked",
        "degraded"
      ]
    },
    "command": {
      "type": "string",
      "enum": [
        "precheck",
        "plan",
        "apply",
        "verify",
        "rollback",
        "observe",
        "capture-artifacts"
      ]
    },
    "scope": {
      "type": "string",
      "enum": [
        "gnb",
        "cu_cp",
        "cu_up",
        "du",
        "cell",
        "ru",
        "ru_link",
        "ue_session",
        "transport_profile",
        "target_host",
        "core_link",
        "replacement_cutover"
      ]
    },
    "change_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "incident_id": {
      "type": [
        "string",
        "null"
      ]
    },
    "target_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "target_profile": {
      "type": [
        "string",
        "null"
      ]
    },
    "core_profile": {
      "type": [
        "string",
        "null"
      ]
    },
    "conformance_claim": {
      "$ref": "#/$defs/conformance_claim"
    },
    "core_endpoint": {
      "$ref": "#/$defs/core_endpoint"
    },
    "gate_class": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "blocked",
        "degraded",
        "pass",
        null
      ]
    },
    "failure_class": {
      "$ref": "#/$defs/failureClass"
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "ngap_subset": {
      "$ref": "#/$defs/ngapSubset"
    },
    "protocol_claims": {
      "$ref": "#/$defs/protocolClaims"
    },
    "target_backend": {
      "type": [
        "string",
        "null"
      ]
    },
    "rollback_target": {
      "type": [
        "string",
        "null"
      ]
    },
    "restored_from": {
      "type": [
        "string",
        "null"
      ]
    },
    "approval_required": {
      "type": "boolean"
    },
    "rollback_available": {
      "type": "boolean"
    },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "suggested_next": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "name",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "enum": [
              "ok",
              "failed",
              "blocked",
              "degraded"
            ]
          },
          "detail": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "plane_status": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "s_plane": {
          "$ref": "#/$defs/plane_summary"
        },
        "m_plane": {
          "$ref": "#/$defs/plane_summary"
        },
        "c_plane": {
          "$ref": "#/$defs/plane_summary"
        },
        "u_plane": {
          "$ref": "#/$defs/plane_summary"
        }
      }
    },
    "interface_status": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "ngap": {
          "$ref": "#/$defs/component_summary"
        },
        "f1_c": {
          "$ref": "#/$defs/component_summary"
        },
        "e1ap": {
          "$ref": "#/$defs/component_summary"
        },
        "f1_u": {
          "$ref": "#/$defs/component_summary"
        },
        "gtpu": {
          "$ref": "#/$defs/component_summary"
        },
        "ru_fronthaul": {
          "$ref": "#/$defs/component_summary"
        },
        "ptp": {
          "$ref": "#/$defs/component_summary"
        }
      }
    },
    "ru_status": {
      "$ref": "#/$defs/component_summary"
    },
    "core_link_status": {
      "$ref": "#/$defs/component_summary"
    },
    "ngap_procedure_trace": {
      "$ref": "#/$defs/procedure_trace"
    },
    "attach_status": {
      "$ref": "#/$defs/component_summary"
    },
    "pdu_session_status": {
      "$ref": "#/$defs/component_summary"
    },
    "ping_status": {
      "$ref": "#/$defs/component_summary"
    },
    "release_status": {
      "$ref": "#/$defs/component_summary"
    },
    "rollback_status": {
      "$ref": "#/$defs/component_summary"
    }
  },
  "$defs": {
    "failureClass": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "ru_failure",
        "core_failure",
        "user_plane_failure",
        "cutover_or_rollback_failure",
        null
      ]
    },
    "ngapSubset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standards_subset_ref",
        "procedure_matrix_ref",
        "required_procedures",
        "supported_procedures",
        "deferred_procedures"
      ],
      "properties": {
        "standards_subset_ref": {
          "type": "string",
          "const": "subprojects/ran_replacement/notes/06-ngap-and-registration-standards-subset.md"
        },
        "procedure_matrix_ref": {
          "type": "string",
          "const": "subprojects/ran_replacement/notes/09-ngap-procedure-support-matrix.md"
        },
        "required_procedures": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "NG Setup",
              "Initial UE Message",
              "Uplink NAS Transport",
              "Downlink NAS Transport",
              "UE Context Release"
            ]
          }
        },
        "supported_procedures": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "Error Indication",
              "Reset"
            ]
          }
        },
        "deferred_procedures": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "Paging",
              "Handover Preparation",
              "Path Switch Request"
            ]
          }
        }
      }
    },
    "conformance_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "evidence_tier",
        "baseline_ref"
      ],
      "properties": {
        "profile": {
          "type": "string",
          "minLength": 1
        },
        "evidence_tier": {
          "type": "string",
          "enum": [
            "milestone_proof",
            "standards_subset"
          ]
        },
        "baseline_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "protocolClaims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ngap",
        "f1_c",
        "e1ap",
        "f1_u",
        "gtpu"
      ],
      "properties": {
        "ngap": {
          "$ref": "#/$defs/ngapSubset"
        },
        "f1_c": {
          "$ref": "#/$defs/namedProcedureSubset"
        },
        "e1ap": {
          "$ref": "#/$defs/namedProcedureSubset"
        },
        "f1_u": {
          "$ref": "#/$defs/namedProcedureSubset"
        },
        "gtpu": {
          "$ref": "#/$defs/namedProcedureSubset"
        }
      }
    },
    "namedProcedureSubset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standards_subset_ref",
        "procedure_matrix_ref",
        "required_procedures",
        "supported_procedures",
        "deferred_procedures"
      ],
      "properties": {
        "standards_subset_ref": {
          "type": "string",
          "minLength": 1
        },
        "procedure_matrix_ref": {
          "type": "string",
          "minLength": 1
        },
        "required_procedures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "supported_procedures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "deferred_procedures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "plane_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "failed",
            "blocked",
            "degraded"
          ]
        },
        "evidence_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "core_endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "n2",
        "n3"
      ],
      "properties": {
        "profile": {
          "type": "string",
          "minLength": 1
        },
        "release_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "n2": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "amf_host",
            "amf_port"
          ],
          "properties": {
            "amf_host": {
              "type": "string",
              "minLength": 1
            },
            "amf_port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "bind_host": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "n3": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "upf_host",
            "gtpu_port",
            "dnn"
          ],
          "properties": {
            "upf_host": {
              "type": "string",
              "minLength": 1
            },
            "gtpu_port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "dnn": {
              "type": "string",
              "minLength": 1
            },
            "slice": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "sst": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 255
                },
                "sd": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              }
            }
          }
        }
      }
    },
    "component_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "failed",
            "blocked",
            "degraded",
            "pending"
          ]
        },
        "evidence_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "reason": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "procedure_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "status",
        "evidence_ref"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "failed",
            "blocked",
            "degraded",
            "pending"
          ]
        },
        "evidence_ref": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "procedure_trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "last_observed",
        "procedures"
      ],
      "properties": {
        "last_observed": {
          "type": "string",
          "minLength": 1
        },
        "procedures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/procedure_summary"
          }
        }
      }
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "command": {
            "const": "verify"
          }
        },
        "required": [
          "command"
        ]
      },
      "then": {
        "required": [
          "gate_class",
          "interface_status"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "capture-artifacts"
          }
        },
        "required": [
          "command"
        ]
      },
      "then": {
        "required": [
          "artifacts"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "scope": {
            "const": "ue_session"
          }
        },
        "required": [
          "scope"
        ]
      },
      "then": {
        "required": [
          "interface_status",
          "core_endpoint",
          "core_link_status",
          "ngap_procedure_trace",
          "release_status",
          "attach_status",
          "pdu_session_status",
          "ping_status"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "scope": {
            "const": "target_host"
          }
        },
        "required": [
          "scope"
        ]
      },
      "then": {
        "required": [
          "ru_status",
          "core_link_status",
          "core_endpoint"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "command": {
            "const": "rollback"
          }
        },
        "required": [
          "command"
        ]
      },
      "then": {
        "required": [
          "rollback_status"
        ]
      }
    }
  ]
}
