{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-ran-agent.local/subprojects/ran_replacement/contracts/compare-report-v1.schema.json",
  "title": "RAN Replacement Compare Report v1",
  "description": "Draft schema for replacement-track compare-report artifacts. The report summarizes expected versus observed state for a declared milestone-1 scope, records the conformance tier being claimed, and must stay readable without SSH access.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "change_id",
    "incident_id",
    "target_profile",
    "core_profile",
    "conformance_claim",
    "core_endpoint",
    "comparison_scope",
    "expected_state",
    "observed_state",
    "gate_class",
    "failure_class",
    "ngap_subset",
    "protocol_claims",
    "diff_summary",
    "evidence_refs",
    "rollback_target",
    "operator_next_step"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "minLength": 1
    },
    "change_id": {
      "type": "string",
      "minLength": 1
    },
    "incident_id": {
      "type": "string",
      "minLength": 1
    },
    "target_profile": {
      "type": "string",
      "minLength": 1
    },
    "core_profile": {
      "type": "string",
      "minLength": 1
    },
    "conformance_claim": {
      "$ref": "#/$defs/conformance_claim"
    },
    "core_endpoint": {
      "$ref": "#/$defs/core_endpoint"
    },
    "comparison_scope": {
      "type": "string",
      "enum": [
        "ngap",
        "f1_c",
        "e1ap",
        "f1_u",
        "gtpu",
        "ru_sync",
        "registration",
        "pdu_session",
        "ping",
        "cutover"
      ]
    },
    "expected_state": {
      "type": "object",
      "additionalProperties": true
    },
    "observed_state": {
      "type": "object",
      "additionalProperties": true
    },
    "gate_class": {
      "type": "string",
      "enum": [
        "blocked",
        "degraded",
        "pass"
      ]
    },
    "failure_class": {
      "$ref": "#/$defs/failureClass"
    },
    "ngap_subset": {
      "$ref": "#/$defs/ngapSubset"
    },
    "protocol_claims": {
      "$ref": "#/$defs/protocolClaims"
    },
    "diff_summary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rollback_target": {
      "type": "string",
      "minLength": 1
    },
    "summary": {
      "type": "string",
      "minLength": 1
    },
    "operator_next_step": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "failureClass": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "ru_failure",
        "core_failure",
        "user_plane_failure",
        "cutover_or_rollback_failure",
        null
      ]
    },
    "ngapSubset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standards_subset_ref",
        "procedure_matrix_ref",
        "required_procedures",
        "bounded_claimed_procedures",
        "deferred_procedures"
      ],
      "properties": {
        "standards_subset_ref": {
          "type": "string",
          "const": "subprojects/ran_replacement/notes/06-ngap-and-registration-standards-subset.md"
        },
        "procedure_matrix_ref": {
          "type": "string",
          "const": "subprojects/ran_replacement/notes/09-ngap-procedure-support-matrix.md"
        },
        "required_procedures": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "NG Setup",
              "Initial UE Message",
              "Uplink NAS Transport",
              "Downlink NAS Transport",
              "UE Context Release"
            ]
          }
        },
        "bounded_claimed_procedures": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "Error Indication",
              "Reset"
            ]
          }
        },
        "deferred_procedures": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "Paging",
              "Handover Preparation",
              "Path Switch Request"
            ]
          }
        }
      }
    },
    "protocolClaims": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ngap",
        "f1_c",
        "e1ap",
        "f1_u",
        "gtpu"
      ],
      "properties": {
        "ngap": {
          "$ref": "#/$defs/ngapSubset"
        },
        "f1_c": {
          "$ref": "#/$defs/namedProcedureSubset"
        },
        "e1ap": {
          "$ref": "#/$defs/namedProcedureSubset"
        },
        "f1_u": {
          "$ref": "#/$defs/namedProcedureSubset"
        },
        "gtpu": {
          "$ref": "#/$defs/namedProcedureSubset"
        }
      }
    },
    "namedProcedureSubset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standards_subset_ref",
        "procedure_matrix_ref",
        "required_procedures",
        "optional_procedures",
        "deferred_procedures"
      ],
      "properties": {
        "standards_subset_ref": {
          "type": "string",
          "minLength": 1
        },
        "procedure_matrix_ref": {
          "type": "string",
          "minLength": 1
        },
        "required_procedures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "optional_procedures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "deferred_procedures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "conformance_claim": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "evidence_tier",
        "baseline_ref"
      ],
      "properties": {
        "profile": {
          "type": "string",
          "minLength": 1
        },
        "evidence_tier": {
          "type": "string",
          "enum": [
            "milestone_proof",
            "standards_subset"
          ]
        },
        "baseline_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "core_endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "n2",
        "n3"
      ],
      "properties": {
        "profile": {
          "type": "string",
          "minLength": 1
        },
        "release_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "n2": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "amf_host",
            "amf_port"
          ],
          "properties": {
            "amf_host": {
              "type": "string",
              "minLength": 1
            },
            "amf_port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "bind_host": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "n3": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "upf_host",
            "gtpu_port",
            "dnn"
          ],
          "properties": {
            "upf_host": {
              "type": "string",
              "minLength": 1
            },
            "gtpu_port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "dnn": {
              "type": "string",
              "minLength": 1
            },
            "slice": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "sst": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 255
                },
                "sd": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
