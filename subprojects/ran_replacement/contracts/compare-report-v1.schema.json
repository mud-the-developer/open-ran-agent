{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-ran-agent.local/subprojects/ran_replacement/contracts/compare-report-v1.schema.json",
  "title": "RAN Replacement Compare Report v1",
  "description": "Draft schema for replacement-track compare-report artifacts. The report summarizes expected versus observed state for a declared milestone-1 scope and must stay readable without SSH access.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "report_id",
    "change_id",
    "incident_id",
    "target_profile",
    "core_profile",
    "core_endpoint",
    "comparison_scope",
    "expected_state",
    "observed_state",
    "ngap_procedure_trace",
    "gate_class",
    "diff_summary",
    "evidence_refs",
    "rollback_target",
    "operator_next_step"
  ],
  "properties": {
    "report_id": {
      "type": "string",
      "minLength": 1
    },
    "change_id": {
      "type": "string",
      "minLength": 1
    },
    "incident_id": {
      "type": "string",
      "minLength": 1
    },
    "target_profile": {
      "type": "string",
      "minLength": 1
    },
    "core_profile": {
      "type": "string",
      "minLength": 1
    },
    "core_endpoint": {
      "$ref": "#/$defs/core_endpoint"
    },
    "comparison_scope": {
      "type": "string",
      "enum": [
        "ngap",
        "f1_c",
        "e1ap",
        "f1_u",
        "gtpu",
        "ru_sync",
        "registration",
        "pdu_session",
        "ping",
        "cutover"
      ]
    },
    "expected_state": {
      "type": "object",
      "additionalProperties": true
    },
    "observed_state": {
      "type": "object",
      "additionalProperties": true
    },
    "ngap_procedure_trace": {
      "$ref": "#/$defs/procedure_trace"
    },
    "gate_class": {
      "type": "string",
      "enum": [
        "blocked",
        "degraded",
        "pass"
      ]
    },
    "diff_summary": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "rollback_target": {
      "type": "string",
      "minLength": 1
    },
    "operator_next_step": {
      "type": "string",
      "minLength": 1
    }
  },
  "$defs": {
    "procedure_summary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "name",
        "status",
        "evidence_ref"
      ],
      "properties": {
        "name": {
          "type": "string",
          "minLength": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "failed",
            "blocked",
            "degraded",
            "pending"
          ]
        },
        "evidence_ref": {
          "type": "string",
          "minLength": 1
        },
        "detail": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "procedure_trace": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "required_procedures",
        "last_observed",
        "last_succeeded",
        "last_failed",
        "procedures"
      ],
      "properties": {
        "required_procedures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "last_observed": {
          "type": "string",
          "minLength": 1
        },
        "last_succeeded": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "last_failed": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "procedures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/procedure_summary"
          }
        }
      }
    },
    "core_endpoint": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "profile",
        "n2",
        "n3"
      ],
      "properties": {
        "profile": {
          "type": "string",
          "minLength": 1
        },
        "release_ref": {
          "type": [
            "string",
            "null"
          ]
        },
        "n2": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "amf_host",
            "amf_port"
          ],
          "properties": {
            "amf_host": {
              "type": "string",
              "minLength": 1
            },
            "amf_port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "bind_host": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "n3": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "upf_host",
            "gtpu_port",
            "dnn"
          ],
          "properties": {
            "upf_host": {
              "type": "string",
              "minLength": 1
            },
            "gtpu_port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "dnn": {
              "type": "string",
              "minLength": 1
            },
            "slice": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "sst": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 255
                },
                "sd": {
                  "type": [
                    "string",
                    "null"
                  ]
                }
              }
            }
          }
        }
      }
    }
  }
}
