{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-ran-agent.local/subprojects/ran_replacement/contracts/n79-single-ru-target-profile-v1.schema.json",
  "title": "n79 Single-RU Target Profile v1",
  "description": "Draft schema for the milestone-1 replacement target profile. It captures the fixed n79 lab assumptions, real Open5GS core interop, explicit S/M/C/U ownership, and the evidence paths required for attach-plus-ping acceptance.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile",
    "profile_family",
    "ru_family",
    "core_family",
    "family_bundle_ref",
    "support_matrix_delta_refs",
    "evidence_bundle_root",
    "scope",
    "rf_profile",
    "ru_boundary",
    "ue_boundary",
    "core_boundary",
    "host_boundary",
    "standards_subset",
    "acceptance_chain",
    "evidence_paths",
    "compatibility_surface"
  ],
  "properties": {
    "profile": {
      "type": "string",
      "const": "n79_single_ru_single_ue_lab_v1"
    },
    "profile_family": {
      "type": "string",
      "minLength": 1
    },
    "ru_family": {
      "type": "string",
      "minLength": 1
    },
    "core_family": {
      "type": "string",
      "minLength": 1
    },
    "family_bundle_ref": {
      "type": "string",
      "minLength": 1
    },
    "support_matrix_delta_refs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "evidence_bundle_root": {
      "type": "string",
      "minLength": 1
    },
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "band",
        "real_ru_required",
        "real_ue_required",
        "real_open5gs_required",
        "target_host_ref"
      ],
      "properties": {
        "band": {
          "type": "string",
          "const": "n79"
        },
        "real_ru_required": {
          "type": "boolean",
          "const": true
        },
        "real_ue_required": {
          "type": "boolean",
          "const": true
        },
        "real_open5gs_required": {
          "type": "boolean",
          "const": true
        },
        "target_host_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "rf_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "band",
        "channel_bandwidth_mhz",
        "numerology",
        "subcarrier_spacing_khz",
        "tdd_pattern",
        "prb_count",
        "antenna_count",
        "pci",
        "tac",
        "plmn"
      ],
      "properties": {
        "band": {
          "type": "string",
          "const": "n79"
        },
        "channel_bandwidth_mhz": {
          "type": "integer",
          "minimum": 1
        },
        "numerology": {
          "type": "integer",
          "minimum": 0,
          "maximum": 5
        },
        "subcarrier_spacing_khz": {
          "type": "integer",
          "minimum": 0
        },
        "tdd_pattern": {
          "type": "string",
          "minLength": 1
        },
        "prb_count": {
          "type": "integer",
          "minimum": 1
        },
        "antenna_count": {
          "type": "integer",
          "minimum": 1
        },
        "pci": {
          "type": "integer",
          "minimum": 0,
          "maximum": 1007
        },
        "tac": {
          "type": "integer",
          "minimum": 0,
          "maximum": 16777215
        },
        "plmn": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ru_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "vendor_or_class",
        "fronthaul_mode",
        "sync_source",
        "device_mapping",
        "timing_dependencies",
        "healthy_indicators",
        "readiness_evidence_ref"
      ],
      "properties": {
        "vendor_or_class": {
          "type": "string",
          "minLength": 1
        },
        "fronthaul_mode": {
          "type": "string",
          "minLength": 1
        },
        "sync_source": {
          "type": "string",
          "minLength": 1
        },
        "device_mapping": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "timing_dependencies": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "healthy_indicators": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "readiness_evidence_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "ue_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "device_class",
        "sim_profile",
        "subscriber_ref",
        "logging_path",
        "attach_evidence_ref",
        "ping_evidence_ref"
      ],
      "properties": {
        "device_class": {
          "type": "string",
          "minLength": 1
        },
        "sim_profile": {
          "type": "string",
          "minLength": 1
        },
        "subscriber_ref": {
          "type": "string",
          "minLength": 1
        },
        "logging_path": {
          "type": "string",
          "minLength": 1
        },
        "attach_evidence_ref": {
          "type": "string",
          "minLength": 1
        },
        "ping_evidence_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "core_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "open5gs_profile",
        "release_ref",
        "n2",
        "n3",
        "subscriber_profile",
        "session_profile",
        "registration_evidence_ref",
        "pdu_session_evidence_ref"
      ],
      "properties": {
        "open5gs_profile": {
          "type": "string",
          "minLength": 1
        },
        "release_ref": {
          "type": "string",
          "minLength": 1
        },
        "n2": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "amf_host",
            "amf_port",
            "bind_host"
          ],
          "properties": {
            "amf_host": {
              "type": "string",
              "minLength": 1
            },
            "amf_port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "bind_host": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "n3": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "upf_host",
            "gtpu_port",
            "dnn",
            "slice"
          ],
          "properties": {
            "upf_host": {
              "type": "string",
              "minLength": 1
            },
            "gtpu_port": {
              "type": "integer",
              "minimum": 1,
              "maximum": 65535
            },
            "dnn": {
              "type": "string",
              "minLength": 1
            },
            "slice": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "sst",
                "sd"
              ],
              "properties": {
                "sst": {
                  "type": "integer",
                  "minimum": 0,
                  "maximum": 255
                },
                "sd": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          }
        },
        "subscriber_profile": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "imsi_ref",
            "ue_class"
          ],
          "properties": {
            "imsi_ref": {
              "type": "string",
              "minLength": 1
            },
            "ue_class": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "session_profile": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "pdu_type",
            "expect_ping_target"
          ],
          "properties": {
            "pdu_type": {
              "type": "string",
              "enum": [
                "ipv4",
                "ipv6",
                "ipv4v6"
              ]
            },
            "expect_ping_target": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        "registration_evidence_ref": {
          "type": "string",
          "minLength": 1
        },
        "pdu_session_evidence_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "host_boundary": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "os",
        "kernel",
        "hugepages",
        "cpu_isolation",
        "ptp_or_gps",
        "nic_timestamping",
        "deployment_layout",
        "preflight_evidence_ref"
      ],
      "properties": {
        "os": {
          "type": "string",
          "minLength": 1
        },
        "kernel": {
          "type": "string",
          "minLength": 1
        },
        "hugepages": {
          "type": "string",
          "minLength": 1
        },
        "cpu_isolation": {
          "type": "string",
          "minLength": 1
        },
        "ptp_or_gps": {
          "type": "string",
          "minLength": 1
        },
        "nic_timestamping": {
          "type": "string",
          "minLength": 1
        },
        "deployment_layout": {
          "type": "string",
          "minLength": 1
        },
        "preflight_evidence_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "standards_subset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "ngap",
        "f1_c",
        "f1_u",
        "e1ap",
        "gtpu"
      ],
      "properties": {
        "ngap": {
          "$ref": "#/$defs/ngap_procedure_subset"
        },
        "f1_c": {
          "$ref": "#/$defs/f1c_procedure_subset"
        },
        "f1_u": {
          "$ref": "#/$defs/f1u_procedure_subset"
        },
        "e1ap": {
          "$ref": "#/$defs/e1ap_procedure_subset"
        },
        "gtpu": {
          "$ref": "#/$defs/gtpu_procedure_subset"
        }
      }
    },
    "acceptance_chain": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "step",
          "evidence_ref",
          "pass_criteria"
        ],
        "properties": {
          "step": {
            "type": "string",
            "minLength": 1
          },
          "evidence_ref": {
            "type": "string",
            "minLength": 1
          },
          "pass_criteria": {
            "type": "string",
            "minLength": 1
          },
          "rollback_trigger": {
            "type": [
              "string",
              "null"
            ]
          }
        }
      }
    },
    "evidence_paths": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "host_preflight",
        "ru_sync",
        "gnb_runtime_health",
        "registration_logs",
        "pdu_session_logs",
        "attach_logs",
        "ping_result",
        "rollback_target_ref",
        "rollback_evidence_ref"
      ],
      "properties": {
        "host_preflight": {
          "type": "string",
          "minLength": 1
        },
        "ru_sync": {
          "type": "string",
          "minLength": 1
        },
        "gnb_runtime_health": {
          "type": "string",
          "minLength": 1
        },
        "registration_logs": {
          "type": "string",
          "minLength": 1
        },
        "pdu_session_logs": {
          "type": "string",
          "minLength": 1
        },
        "attach_logs": {
          "type": "string",
          "minLength": 1
        },
        "ping_result": {
          "type": "string",
          "minLength": 1
        },
        "rollback_target_ref": {
          "type": "string",
          "minLength": 1
        },
        "rollback_evidence_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "compatibility_surface": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "compatibility_profile",
        "required_nf_set",
        "required_io_surfaces",
        "declared_deviations",
        "evidence_ref"
      ],
      "properties": {
        "compatibility_profile": {
          "type": "string",
          "const": "open5gs_public_surface_ran_visible_v1"
        },
        "required_nf_set": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "required_io_surfaces": {
          "type": "array",
          "minItems": 3,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "declared_deviations": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "evidence_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  },
  "$defs": {
    "ngap_procedure_subset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standards_subset_ref",
        "procedure_matrix_ref",
        "required_procedures",
        "optional_procedures",
        "deferred_procedures"
      ],
      "properties": {
        "standards_subset_ref": {
          "type": "string",
          "const": "subprojects/ran_replacement/notes/06-ngap-and-registration-standards-subset.md"
        },
        "procedure_matrix_ref": {
          "type": "string",
          "const": "subprojects/ran_replacement/notes/09-ngap-procedure-support-matrix.md"
        },
        "required_procedures": {
          "type": "array",
          "minItems": 5,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "NG Setup",
              "Initial UE Message",
              "Uplink NAS Transport",
              "Downlink NAS Transport",
              "UE Context Release"
            ]
          }
        },
        "optional_procedures": {
          "type": "array",
          "minItems": 2,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "Error Indication",
              "Reset"
            ]
          }
        },
        "deferred_procedures": {
          "type": "array",
          "minItems": 3,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "Paging",
              "Handover Preparation",
              "Path Switch Request"
            ]
          }
        }
      }
    },
    "f1c_procedure_subset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standards_subset_ref",
        "procedure_matrix_ref",
        "required_procedures",
        "optional_procedures",
        "deferred_procedures"
      ],
      "properties": {
        "standards_subset_ref": {
          "type": "string",
          "const": "subprojects/ran_replacement/notes/07-f1-c-and-e1ap-standards-subset.md"
        },
        "procedure_matrix_ref": {
          "type": "string",
          "const": "subprojects/ran_replacement/notes/10-f1-c-and-e1ap-procedure-support-matrix.md"
        },
        "required_procedures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "optional_procedures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "deferred_procedures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "e1ap_procedure_subset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standards_subset_ref",
        "procedure_matrix_ref",
        "required_procedures",
        "optional_procedures",
        "deferred_procedures"
      ],
      "properties": {
        "standards_subset_ref": {
          "type": "string",
          "const": "subprojects/ran_replacement/notes/07-f1-c-and-e1ap-standards-subset.md"
        },
        "procedure_matrix_ref": {
          "type": "string",
          "const": "subprojects/ran_replacement/notes/10-f1-c-and-e1ap-procedure-support-matrix.md"
        },
        "required_procedures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "optional_procedures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "deferred_procedures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "f1u_procedure_subset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standards_subset_ref",
        "procedure_matrix_ref",
        "required_procedures",
        "optional_procedures",
        "deferred_procedures"
      ],
      "properties": {
        "standards_subset_ref": {
          "type": "string",
          "const": "subprojects/ran_replacement/notes/08-f1-u-and-gtpu-standards-subset.md"
        },
        "procedure_matrix_ref": {
          "type": "string",
          "const": "subprojects/ran_replacement/notes/11-f1-u-and-gtpu-procedure-support-matrix.md"
        },
        "required_procedures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "optional_procedures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "deferred_procedures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "gtpu_procedure_subset": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "standards_subset_ref",
        "procedure_matrix_ref",
        "required_procedures",
        "optional_procedures",
        "deferred_procedures"
      ],
      "properties": {
        "standards_subset_ref": {
          "type": "string",
          "const": "subprojects/ran_replacement/notes/08-f1-u-and-gtpu-standards-subset.md"
        },
        "procedure_matrix_ref": {
          "type": "string",
          "const": "subprojects/ran_replacement/notes/11-f1-u-and-gtpu-procedure-support-matrix.md"
        },
        "required_procedures": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "optional_procedures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "deferred_procedures": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
