{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://open-ran-agent.local/subprojects/ran_replacement/contracts/open5gs-core-link-profile-v1.schema.json",
  "title": "Open5GS Core Link Profile v1",
  "description": "Draft schema for the real Open5GS core assumptions used by the RAN replacement track. This is a target-profile contract, not a claim of full core ownership.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "profile",
    "n2",
    "n3",
    "subscriber_profile",
    "session_profile"
  ],
  "properties": {
    "profile": {
      "type": "string",
      "minLength": 1
    },
    "release_ref": {
      "type": [
        "string",
        "null"
      ]
    },
    "n2": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "amf_host",
        "amf_port"
      ],
      "properties": {
        "amf_host": {
          "type": "string",
          "minLength": 1
        },
        "amf_port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "bind_host": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "n3": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "upf_host",
        "gtpu_port",
        "dnn"
      ],
      "properties": {
        "upf_host": {
          "type": "string",
          "minLength": 1
        },
        "gtpu_port": {
          "type": "integer",
          "minimum": 1,
          "maximum": 65535
        },
        "dnn": {
          "type": "string",
          "minLength": 1
        },
        "slice": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "sst": {
              "type": "integer",
              "minimum": 0,
              "maximum": 255
            },
            "sd": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        }
      }
    },
    "subscriber_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "imsi_ref",
        "ue_class"
      ],
      "properties": {
        "imsi_ref": {
          "type": "string",
          "minLength": 1
        },
        "ue_class": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "session_profile": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "pdu_type",
        "expect_ping_target"
      ],
      "properties": {
        "pdu_type": {
          "type": "string",
          "enum": [
            "ipv4",
            "ipv6",
            "ipv4v6"
          ]
        },
        "expect_ping_target": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
