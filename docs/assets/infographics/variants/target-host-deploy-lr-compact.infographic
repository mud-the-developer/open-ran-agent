infographic relation-dagre-flow-lr-compact-card
data
  title Target-host deploy loop
  desc Preview locally, execute remotely, and fetch evidence back into the same operator loop.
  nodes
    - id package
      label package bundle
      desc mix ran.package_bootstrap
    - id preview
      label preview
      desc ran-install or Deploy Studio
    - id readiness
      label readiness
      desc Profile, effective config, blockers
    - id ship
      label ship bundle
      desc Bundle plus rendered files
    - id preflight
      label remote preflight
      desc Host probe and native readiness
    - id remote
      label remote ranctl
      desc Precheck, plan, apply, verify
    - id fetch
      label fetchback
      desc Remote runs and debug packs
    - id dashboard
      label dashboard
      desc Deploy Studio and Debug Desk
  relations
    package -> preview
    preview -> readiness
    readiness -> ship
    ship -> preflight
    preflight -> remote
    remote -> fetch
    fetch -> dashboard
theme
  palette #92400e #d97706 #0f766e #1d4ed8 #334155 #7c2d12
  base
    text
      font-family Arial, Helvetica, sans-serif
