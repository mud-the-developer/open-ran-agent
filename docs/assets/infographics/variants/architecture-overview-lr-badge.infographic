infographic relation-dagre-flow-lr-badge-card
data
  title Open RAN Agent architecture
  desc Operator surface, BEAM control lanes, native gateway, and evidence capture.
  nodes
    - id ops
      label Operator surface
      desc Dashboard, skills, CI
    - id ranctl
      label bin/ranctl
      desc Single mutable entrypoint
    - id core
      label ran_core / ran_config
      desc Policy and topology
    - id du
      label DU path
      desc DU-high and scheduler host
    - id fapi
      label ran_fapi_core
      desc IR and capability checks
    - id native
      label Native boundary
      desc Port gateway and adapters
    - id runtime
      label Backend runtime
      desc DU-low and vendor workers
    - id evidence
      label Artifacts / evidence
      desc Plans, captures, remote runs
  relations
    ops -> ranctl
    ranctl -> core
    ranctl -> du
    du -> fapi
    fapi -> native
    native -> runtime
    ranctl -> evidence
    core -> evidence
theme
  palette #115e59 #1d4ed8 #0f172a #d97706 #475569
  base
    text
      font-family Arial, Helvetica, sans-serif
