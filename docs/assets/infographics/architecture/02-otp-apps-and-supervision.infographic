infographic hierarchy-tree-lr-tech-style-badge-card
data
  title OTP apps and supervision
  desc Mix umbrella apps restart independently while DU-high and gateway sessions stay scoped under local owners.
  root
    label OpenRanAgent.ReleaseSupervisor
    children
      - label RanCore.Application
        children
          - label RanCore.Topology
          - label RanCore.NodeRegistry
          - label RanCore.ChangeRegistry
      - label RanCuCp.Application
        children
          - label RanCuCp.AssociationSupervisor
      - label RanCuUp.Application
        children
          - label RanCuUp.TunnelSupervisor
      - label RanDuHigh.Application
        children
          - label RanDuHigh.CellGroupSupervisor
            children
              - label cell_group:<id>
                children
                  - label ue_subtree:<id>
                  - label scheduler_session
                  - label fapi_session
          - label RanDuHigh.BackendDrainCoordinator
      - label RanFapiCore.Application
        children
          - label RanFapiCore.ProfileRegistry
          - label RanFapiCore.GatewaySessionSupervisor
      - label RanSchedulerHost.Application
        children
          - label RanSchedulerHost.AdapterSupervisor
      - label RanActionGateway.Application
        children
          - label RanActionGateway.ChangeSupervisor
          - label RanActionGateway.ApprovalGate
      - label RanObservability.Application
        children
          - label RanObservability.ArtifactSupervisor
      - label RanConfig.Application
        children
          - label RanConfig.ProfileCache
theme
  palette #0f766e #1d4ed8 #0f172a #ea580c #475569 #7c3aed
  base
    text
      font-family Arial, Helvetica, sans-serif
